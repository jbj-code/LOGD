# LOGD — copy to `.env.local` for local dev (gitignored).
#
# Omit both vars to use offline localStorage only.
#
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
#
# Production (GitHub Pages): add the same two as repository secrets
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY → Actions uses them at build time.
